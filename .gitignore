# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Android / Bubblewrap build artifacts
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/local.properties
android/manifest-checksum.txt

# NEVER commit these — they are app signing identity
android/android.keystore
*.keystore
*.jks
android/*.apk
android/*.aab
android/*.idsig

# Bubblewrap signing config — contains password references
android/twa-manifest.json

# Sensitive — never commit
android/.keystore-password
android/*.compromised.backup
android/*.backup
